<?xml version="1.0"?>
<robot name="diff_drive_robot">

  <!-- ================= MATERIALS ================= -->
  <material name="red">
    <color rgba="0.8 0.1 0.1 1"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>


  <!-- ================= BASE FOOTPRINT ================= -->
  <link name="base_footprint"/>


  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.171" length="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <visual>
  <geometry>
    <box size="0.0001 0.350 0.072"  />
  </geometry>
</visual>
<visual>
  <geometry>
    <box size="0.350 0.0001  0.072"/>
  </geometry>
</visual>
  </link>

  <joint name="footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.036" rpy="0 0 0"/>
  </joint>


  <!-- ================= LEFT WHEEL ================= -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.036" length="0.008"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>

    <origin xyz="0 0.175 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>


  <!-- Marker fixed to left wheel -->
  <link name="left_wheel_marker">
    <visual>
      <geometry>
        <box size="0.006 0.030 0.002"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="left_wheel_to_marker" type="fixed">
    <parent link="left_wheel"/>
    <child link="left_wheel_marker"/>
    <origin xyz="0 0 0.005" rpy="0 0 0"/>
  </joint>


  <!-- ================= RIGHT WHEEL ================= -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.036" length="0.008"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>

    <origin xyz="0 -0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>


  <!-- Marker fixed to right wheel -->
  <link name="right_wheel_marker">
    <visual>
      <geometry>
        <box size="0.006 0.030 0.002"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="right_wheel_to_marker" type="fixed">
    <parent link="right_wheel"/>
    <child link="right_wheel_marker"/>
    <origin xyz="0 0 0.005" rpy="0 0 0"/>
  </joint>


  <!-- ================= HEAD ================= -->
  <link name="head">
    <visual>
      <geometry>
        <box size="0.015 0.015 0.03"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="base_to_head" type="fixed">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="0.125 0 0.025" rpy="0 0 0"/>
  </joint>


  <!-- ================= PASSIVE WHEEL HOLDER ================= -->
  <link name="passive_wheel_holder">
    <visual>
      <geometry>
        <cylinder radius="0.010" length="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="base_to_passive_holder" type="fixed">
    <parent link="base_link"/>
    <child link="passive_wheel_holder"/>
    <origin xyz="0.125 0 -0.0175" rpy="0 0 0"/>
  </joint>


  <!-- ================= PASSIVE WHEEL ================= -->
  <link name="passive_wheel">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="holder_to_passive_wheel" type="fixed">
    <parent link="passive_wheel_holder"/>
    <child link="passive_wheel"/>
    <origin xyz="0 0 -0.0085" rpy="0 0 0"/>
  </joint>

</robot>