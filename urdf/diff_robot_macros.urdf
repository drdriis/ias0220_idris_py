<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="diff_drive_robot">

  <!-- ================= PROPERTIES ================= -->
  <xacro:property name="base_radius" value="0.171"/>
  <xacro:property name="base_length" value="0.02"/>


  <xacro:property name="wheel_radius" value="0.036"/>
  <xacro:property name="wheel_length" value="0.008"/>
  <xacro:property name="wheel_y_offset" value="0.175"/>

  <xacro:property name="marker_size" value="0.006 0.030 0.002"/>
  <xacro:property name="marker_origin" value="0 0 0.005"/>

  <xacro:property name="head_size" value="0.015 0.015 0.03"/>
  <xacro:property name="head_origin" value="0.125 0 0.025"/>

  <xacro:property name="passive_holder_radius" value="0.010"/>
  <xacro:property name="passive_holder_length" value="0.015"/>
  <xacro:property name="passive_holder_origin" value="0.125 0 -0.0175"/>

  <xacro:property name="passive_wheel_radius" value="0.010"/>
  <xacro:property name="passive_wheel_origin" value="0 0 -0.0085"/>


  <!-- ================= MATERIALS ================= -->
  <material name="red">
    <color rgba="0.8 0.1 0.1 1"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>


  <!-- ================= MACROS ================= -->
  <xacro:macro name="wheel_with_marker" params="side y rpy axis">
    <link name="${side}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <joint name="base_to_${side}_wheel" type="continuous">
      <parent link="base_link"/>
      <child link="${side}_wheel"/>
      <origin xyz="0 ${y} 0" rpy="${rpy}"/>
      <axis xyz="${axis}"/>
    </joint>

    <link name="${side}_wheel_marker">
      <visual>
        <geometry>
          <box size="${marker_size}"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <joint name="${side}_wheel_to_marker" type="fixed">
      <parent link="${side}_wheel"/>
      <child link="${side}_wheel_marker"/>
      <origin xyz="${marker_origin}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>


  <!-- ================= BASE FOOTPRINT ================= -->
  <link name="base_footprint"/>


  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_length}"/>
      </geometry>
      <material name="red"/>
    </visual>


  </link>

  <joint name="footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.036" rpy="0 0 0"/>
  </joint>


  <!-- ================= LEFT WHEEL ================= -->
  <xacro:wheel_with_marker
    side="left"
    y="${wheel_y_offset}"
    rpy="-1.5708 0 0"
    axis="0 0 1"/>


  <!-- ================= RIGHT WHEEL ================= -->
  <xacro:wheel_with_marker
    side="right"
    y="-${wheel_y_offset}"
    rpy="1.5708 0 0"
    axis="0 0 -1"/>


  <!-- ================= HEAD ================= -->
  <link name="head">
    <visual>
      <geometry>
        <box size="${head_size}"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="base_to_head" type="fixed">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="${head_origin}" rpy="0 0 0"/>
  </joint>


  <!-- ================= PASSIVE WHEEL HOLDER ================= -->
  <link name="passive_wheel_holder">
    <visual>
      <geometry>
        <cylinder radius="${passive_holder_radius}" length="${passive_holder_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="base_to_passive_holder" type="fixed">
    <parent link="base_link"/>
    <child link="passive_wheel_holder"/>
    <origin xyz="${passive_holder_origin}" rpy="0 0 0"/>
  </joint>


  <!-- ================= PASSIVE WHEEL ================= -->
  <link name="passive_wheel">
    <visual>
      <geometry>
        <sphere radius="${passive_wheel_radius}"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="holder_to_passive_wheel" type="fixed">
    <parent link="passive_wheel_holder"/>
    <child link="passive_wheel"/>
    <origin xyz="${passive_wheel_origin}" rpy="0 0 0"/>
  </joint>

</robot>