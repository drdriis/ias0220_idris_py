<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="diff_drive_robot">

  <!-- ================= PROPERTIES ================= -->
  <xacro:property name="base_radius" value="0.171" />
  <xacro:property name="base_length" value="0.02" />

  <xacro:property name="wheel_radius" value="0.036" />
  <xacro:property name="wheel_length" value="0.008" />
  <xacro:property name="wheel_y_offset" value="0.175" />

  <xacro:property name="marker_size" value="0.006 0.030 0.002" />
  <xacro:property name="marker_origin" value="0 0 0.005" />

  <xacro:property name="head_size" value="0.015 0.015 0.03" />
  <xacro:property name="head_origin" value="0.125 0 0.025" />

  <xacro:property name="passive_holder_radius" value="0.010" />
  <xacro:property name="passive_holder_length" value="0.015" />
  <xacro:property name="passive_holder_origin" value="0.125 0 -0.0175" />

  <xacro:property name="passive_wheel_radius" value="0.010" />
  <xacro:property name="passive_wheel_origin" value="0 0 -0.0085" />


  <!-- ================= MATERIALS ================= -->
  <material name="red">
    <color rgba="0.8 0.1 0.1 1" />
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1" />
  </material>
  <material name="white">
    <color rgba="1 1 1 1" />
  </material>
  <material name="blue">
    <color rgba="0 0 1 1" />
  </material>


  <!-- ================= WHEEL MACRO ================= -->
  <xacro:macro name="wheel_with_marker" params="side y rpy axis">

    <link name="${side}_wheel">

      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}" />
        </geometry>
        <material name="black" />
      </visual>

      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" />
        <mass value="0.025" />
        <inertia
          ixx="8.2333e-06" ixy="0" ixz="0"
          iyy="8.2333e-06" iyz="0"
          izz="1.62e-05" />
      </inertial>

    </link>

    <joint name="base_to_${side}_wheel" type="continuous">
      <parent link="base_link" />
      <child link="${side}_wheel" />
      <origin xyz="0 ${y} 0" rpy="${rpy}" />
      <axis xyz="${axis}" />
    </joint>

    <link name="${side}_wheel_marker">
      <visual>
        <geometry>
          <box size="${marker_size}" />
        </geometry>
        <material name="white" />
      </visual>

      <collision>
        <geometry>
          <box size="${marker_size}" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" />
        <mass value="0.001" />
        <inertia
          ixx="1e-09" ixy="0" ixz="0"
          iyy="1e-09" iyz="0"
          izz="1e-09" />
      </inertial>

    </link>

    <joint name="${side}_wheel_to_marker" type="revolute">
      <parent link="${side}_wheel" />
      <child link="${side}_wheel_marker" />
      <origin xyz="${marker_origin}" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="0" effort="0" velocity="0" />
    </joint>

  </xacro:macro>


  <!-- ================= BASE FOOTPRINT ================= -->
  <link name="base_footprint" />


  <!-- ================= BASE LINK ================= -->
  <link name="base_link">

    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_length}" />
      </geometry>
      <material name="red" />
    </visual>

    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_length}" />
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.200" />
      <inertia
        ixx="0.0014687" ixy="0" ixz="0"
        iyy="0.0014687" iyz="0"
        izz="0.0029241" />
    </inertial>

  </link>

  <joint name="footprint_to_base" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.036" />
  </joint>


  <!-- ================= WHEELS ================= -->
  <xacro:wheel_with_marker side="left" y="${wheel_y_offset}" rpy="-1.5708 0 0" axis="0 0 1" />
  <xacro:wheel_with_marker side="right" y="-${wheel_y_offset}" rpy="1.5708 0 0" axis="0 0 -1" />


  <!-- ================= HEAD ================= -->
  <link name="head">

    <visual>
      <geometry>
        <box size="${head_size}" />
      </geometry>
      <material name="blue" />
    </visual>

    <collision>
      <geometry>
        <box size="${head_size}" />
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.020" />
      <inertia
        ixx="1.875e-06" ixy="0" ixz="0"
        iyy="1.875e-06" iyz="0"
        izz="7.5e-07" />
    </inertial>

  </link>

  <joint name="base_to_head" type="fixed">
    <parent link="base_link" />
    <child link="head" />
    <origin xyz="${head_origin}" />
  </joint>


  <!-- ================= PASSIVE HOLDER ================= -->
  <link name="passive_wheel_holder">

    <visual>
      <geometry>
        <cylinder radius="${passive_holder_radius}" length="${passive_holder_length}" />
      </geometry>
      <material name="white" />
    </visual>

    <collision>
      <geometry>
        <cylinder radius="${passive_holder_radius}" length="${passive_holder_length}" />
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.015" />
      <inertia
        ixx="6.5625e-07" ixy="0" ixz="0"
        iyy="6.5625e-07" iyz="0"
        izz="7.5e-07" />
    </inertial>

  </link>

  <joint name="base_to_passive_holder" type="fixed">
    <parent link="base_link" />
    <child link="passive_wheel_holder" />
    <origin xyz="${passive_holder_origin}" />
  </joint>


  <!-- ================= PASSIVE WHEEL ================= -->
  <link name="passive_wheel">

    <visual>
      <geometry>
        <sphere radius="${passive_wheel_radius}" />
      </geometry>
      <material name="white" />
    </visual>

    <collision>
      <geometry>
        <sphere radius="${passive_wheel_radius}" />
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.010" />
      <inertia
        ixx="4e-07" ixy="0" ixz="0"
        iyy="4e-07" iyz="0"
        izz="4e-07" />
    </inertial>

  </link>

  <joint name="holder_to_passive_wheel" type="fixed">
    <parent link="passive_wheel_holder" />
    <child link="passive_wheel" />
    <origin xyz="${passive_wheel_origin}" />
  </joint>


  <!-- ================= GAZEBO MATERIAL COLORS ================= -->

  <gazebo reference="base_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="head">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="passive_wheel_holder">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="passive_wheel">
    <material>Gazebo/White</material>
  </gazebo>

  <!-- Left wheel: non-zero friction (actuated) -->
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- Right wheel: non-zero friction (actuated) -->
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="left_wheel_marker">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="right_wheel_marker">
    <material>Gazebo/White</material>
  </gazebo>


  <!-- ================= GAZEBO DIFFERENTIAL DRIVE PLUGIN ================= -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">

      <!-- Wheel joints -->
      <left_joint>base_to_left_wheel</left_joint>
      <right_joint>base_to_right_wheel</right_joint>

      <!-- Wheel geometry — must match your model -->
      <wheel_separation>0.350</wheel_separation>
      <wheel_diameter>0.072</wheel_diameter>

      <!-- Limits -->
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- Command topic (input from teleop) -->
      <command_topic>cmd_vel</command_topic>

      <!-- Odometry -->
      <odometry_source>0</odometry_source>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>

      <!-- Remap odom topic -->
      <ros>
        <remapping>odom:=diff_cont/odom</remapping>
      </ros>

      <!-- Publish rate -->
      <publish_rate>50</publish_rate>
      <publish_wheel_tf>true</publish_wheel_tf>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>

      <update_rate>100</update_rate>

    </plugin>
  </gazebo>


  <!-- ================= GAZEBO GROUND TRUTH PLUGIN ================= -->
  <gazebo>
    <plugin name="p3d_base_controller" filename="libgazebo_ros_p3d.so">
      <ros>
        <remapping>odom:=ground_truth</remapping>
      </ros>
      <update_rate>50.0</update_rate>
      <body_name>base_footprint</body_name>
      <gaussian_noise>0.0</gaussian_noise>
      <frame_name>odom</frame_name>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
    </plugin>
  </gazebo>
  <!-- Joint state publisher plugin -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher"
      filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>base_to_left_wheel</joint_name>
      <joint_name>base_to_right_wheel</joint_name>
      <joint_name>left_wheel_to_marker</joint_name>
      <joint_name>right_wheel_to_marker</joint_name>
    </plugin>
  </gazebo>


</robot>